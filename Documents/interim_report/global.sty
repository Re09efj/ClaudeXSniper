% コマンド定義
\def\abst#1{\gdef\@abst{#1}}
\def\keywords#1{\gdef\@keywords{#1}}
\def\prof#1{\gdef\@prof{#1}}
\def\asoprof#1{\gdef\@asoprof{#1}}
\def\student#1{\gdef\@student{#1}}
\def\journal#1{\gdef\@journal{#1}}
\def\nendo#1{\gdef\@nendo{#1}}
\def\title#1{\gdef\@title{#1}}
\def\author#1{\gdef\@author{#1}}
\def\date#1{\gdef\@date{#1}}
\def\headertext#1{\gdef\@headertext{#1}}
\def\@headertext{グローバルルーム論文紹介}

% タイトル部（意味を維持しつつ整理）
\def\@maketitle{\newpage
  \null
  {\noindent
    {\large \rlap{\phantom{\@date}}%
    \makebox[\textwidth][c]{\@headertext}%
    \llap{\@date}\par}
    \begin{large}
      \begin{center}
        \vskip 1em
        {\bfseries \@title}\\[1em]
        \@author
      \end{center}
    \end{large}
  }

  % Abstract
  \@ifundefined{@abst}{}{%
    \vskip 1.5em
    {\normalsize
      \begin{list}{{\bf Abstract}:}{
          \setlength{\topsep}{0pt}
          \setlength{\partopsep}{0pt}
          \setlength{\parsep}{0pt}
          \setlength{\baselineskip}{4.25mm}
          \setlength{\leftmargin}{0.05\textwidth}
          \setlength{\rightmargin}{0.05\textwidth}
          \setlength{\itemindent}{0.05\textwidth}
          \setlength{\listparindent}{0mm}
          \setlength{\labelsep}{0pt}
        }
        \item \@abst
        \vskip \baselineskip

        \@ifundefined{@keywords}{}{%
          \begin{list}{{\bf Key Words}:}{
              \setlength{\topsep}{0pt}
              \setlength{\parsep}{0pt}
              \setlength{\partopsep}{0pt}
              \setlength{\listparindent}{0mm}
              \setlength{\baselineskip}{4.25mm}
              \settowidth{\labelwidth}{{\bf Key Words}:}
              \setlength{\labelsep}{0pt}
              \setlength{\leftmargin}{\labelwidth}
              \setlength{\rightmargin}{0mm}
            }
            \item \@keywords
          \end{list}
        }
      \end{list}
    }
  }
  \vskip \baselineskip
}

% セクション定義
\def\section{\@startsection {section}{1}{\z@}{3.25ex plus 1ex minus .2ex}{.4ex plus .1ex}{\large\bf}}
\def\subsection{\@startsection{subsection}{2}{\z@}{1.2ex plus 1ex minus .2ex}{.4ex plus .1ex}{\normalsize\bf}}
\def\subsubsection{\@startsection{subsubsection}{3}{\z@}{1.2ex plus 1ex minus .2ex}{.4ex plus .1ex}{\normalsize\bf}}

% その他の設定（ほぼ元のまま）
\def\@makecaption#1#2{\vskip 10pt \setbox\@tempboxa\hbox{#1. #2}
  \ifdim \wd\@tempboxa >\hsize #1. #2\par \else \hbox to\hsize{\hfil\box\@tempboxa\hfil}\fi}

